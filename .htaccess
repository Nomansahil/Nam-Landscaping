# ============================================================================
# NAM Landscaping — Apache/LiteSpeed config for Hostinger
# Goals: one canonical host (HTTPS, non-www), fast static delivery (compression
# + long cache), security headers, and a proper 404. Tuned for PageSpeed /
# Lighthouse (Performance + Best Practices) and zero Search Console redirect or
# duplicate-URL errors. Every block is guarded so a missing module can't 500.
# ============================================================================

Options -Indexes
DirectoryIndex index.html
ServerSignature Off

# ----------------------------------------------------------------------------
# 1. Canonical host + HTTPS  (must match the <link rel="canonical"> = https://namlandscaping.ae)
#    Redirects:  http://*  ->  https://    and    www.  ->  non-www
#    One 301 hop, so Search Console sees a single canonical origin.
# ----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Canonical host: HTTPS + non-www in one 301 hop.
  # Handles http://, http://www., and https://www. in a single redirect (no double-hop).
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\. [NC]
  RewriteRule ^ https://namlandscaping.ae%{REQUEST_URI} [R=301,L]

  # Trailing slash → serve the page IN PLACE (200, NO redirect) when a matching .html
  # page exists. Fixes /services/ (a real directory of sub-pages) returning 403 without
  # any redirect. Pages use root-absolute asset/link paths, so they render correctly at
  # this depth. The page's <link rel="canonical"> (no slash) keeps a single indexed URL.
  # Real asset directories (no .html twin) are left untouched.
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/$ $1.html [L]

  # Clean URLs: internally serve /page from page.html (no redirect, transparent to client)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ----------------------------------------------------------------------------
# 2. Custom error page (returns a real 404 status -> no Search Console soft-404s)
# ----------------------------------------------------------------------------
ErrorDocument 404 /404.html

# ----------------------------------------------------------------------------
# 3. Compression  (text assets gzip/brotli; images/fonts are already compressed)
# ----------------------------------------------------------------------------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml \
    text/javascript application/javascript application/json application/xml \
    application/rss+xml application/ld+json image/svg+xml application/manifest+json
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    text/javascript application/javascript application/json application/xml \
    application/rss+xml application/ld+json image/svg+xml application/manifest+json
</IfModule>

# ----------------------------------------------------------------------------
# 4. Caching  (content-stable assets cached hard; HTML revalidates fast)
# ----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"
  ExpiresByType text/html                     "access plus 0 seconds"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType text/css                      "access plus 1 week"
  ExpiresByType application/javascript        "access plus 1 week"
  ExpiresByType application/json              "access plus 0 seconds"
  ExpiresByType application/xml               "access plus 1 day"
  ExpiresByType text/plain                    "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Fingerprint-stable assets: cache for a year, immutable.
  <FilesMatch "\.(webp|jpe?g|png|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # CSS/JS filenames aren't content-hashed, so allow weekly revalidation.
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  # HTML: always revalidate so edits surface immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # ------------------------------------------------------------------------
  # 5. Security headers (Best Practices)
  # ------------------------------------------------------------------------
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), browsing-topics=()"
  # HSTS — only meaningful once HTTPS is live (it is, on Hostinger SSL).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Don't leak the proxy's identity.
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ----------------------------------------------------------------------------
# 6. Correct MIME types (some hosts mis-serve these, which can break caching/CWV)
# ----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp                 .webp
  AddType font/woff2                 .woff2
  AddType image/svg+xml              .svg
  AddType application/ld+json        .jsonld
  AddType application/manifest+json  .webmanifest
</IfModule>

# ----------------------------------------------------------------------------
# 7. Protect dotfiles / build sources if they ever get uploaded
# ----------------------------------------------------------------------------
<FilesMatch "(^\.|\.(map|cjs)$)">
  Require all denied
</FilesMatch>
