{
  "name": "nam-landscaping-site",
  "version": "1.0.0",
  "private": true,
  "description": "Static website for NAM Landscaping (Noor Al Madeena Landscaping LLC), Dubai. No framework, no runtime dependencies (sharp is build-time only).",
  "scripts": {
    "build": "node build/build.js",
    "photos": "node scripts/process-photos.js",
    "icons": "node scripts/make-icons.js",
    "check-links": "node build/check-links.js",
    "seo:validate": "node build/validate-seo.js",
    "seo:audit:http": "node scripts/seo-http-audit.js",
    "serve": "npx --yes serve -l 5173 ."
  },
  "devDependencies": {
    "sharp": "^0.35.1"
  }
}
